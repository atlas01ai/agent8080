# Agent8080 Alerts Service — Environment Configuration
# Copy to .env and fill in real values

# =============================================================================
# RPC Configuration (Required)
# =============================================================================
# Get free API key from https://dashboard.alchemy.com/
# 1. Sign up / Log in
# 2. Click "Create new app"
# 3. Select "Base" as network
# 4. Copy the HTTP URL and paste here
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Fallback to public RPC (no API key required, but rate-limited)
BASE_RPC_FALLBACK_URL=https://mainnet.base.org

# =============================================================================
# Discord Bot Configuration (Required)
# =============================================================================
# Create bot at https://discord.com/developers/applications
# Enable "Server Members Intent" and "Message Content Intent"
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: Channel for system alerts (not user DMs)
DISCORD_ALERT_CHANNEL_ID=

# =============================================================================
# Agent Configuration
# =============================================================================
AGENT8080_ADDRESS=0x862c803FEf8C9B28b3c06D67dFc1522534168CeC

# =============================================================================
# Whale Detection Settings
# =============================================================================
WHALE_THRESHOLD_ETH=10.0

# Optional: Comma-separated list of addresses to always watch
# WHALE_WATCHLIST=0xabc...,0xdef...

# =============================================================================
# Polling Configuration
# =============================================================================
POLL_INTERVAL_MS=2500
BLOCK_CONFIRMATIONS=5
REORG_LOOKBACK_BLOCKS=10

# =============================================================================
# Subscription Tiers
# =============================================================================
FREE_TIER_DAILY_LIMIT=5
HEALTH_FACTOR_ALERT_THRESHOLD=1.1

# =============================================================================
# Database
# =============================================================================
DATABASE_PATH=./data/alerts.db

# =============================================================================
# Node Environment
# =============================================================================
NODE_ENV=production
